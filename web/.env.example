# Copy to .env.local for local dev, or set these in the Vercel dashboard.
#
# Without these set, the app automatically falls back to local file storage
# (data/*.json + public/uploads) so `npm run dev` works with zero setup.

# --- Neon Postgres (database) ---
# Add the Neon integration in Vercel (Storage tab) and it will populate this.
# Locally, paste your Neon connection string (use the pooled/-pooler URL).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# --- Vercel Blob (image uploads) ---
# Create a Blob store in Vercel (Storage tab); it sets this token automatically.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# --- Admin auth (password gate) ---
# When set, /admin pages and mutating APIs require signing in at /admin/login.
# Leave unset locally to keep admin open with zero friction.
ADMIN_PASSWORD="choose-a-strong-password"
